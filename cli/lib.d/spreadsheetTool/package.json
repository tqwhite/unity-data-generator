{
  "name": "spreadsheettool",
  "version": "1.0.0",
  "description": "Load and export excel spreadsheets to/from sqlite.",
  "main": "spreadsheetTool.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "@types/jest": "^30.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/**/index.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "author": "TQ White II",
  "license": "ISC"
}
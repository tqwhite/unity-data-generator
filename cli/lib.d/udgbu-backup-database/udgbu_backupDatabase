#!/bin/bash

# udgbu_backupDatabase - Backup vectorTools database with timestamp and rotation
# Author: TQ White II
# Description: Backs up the database specified in vectorTools.ini configuration
#              Maintains a rolling backup of 10 most recent copies

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored messages
print_error() {
    echo -e "${RED}ERROR: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}SUCCESS: $1${NC}"
}

print_info() {
    echo -e "${YELLOW}INFO: $1${NC}"
}

# Check if readConfig is available in PATH
if ! command -v readConfig &> /dev/null; then
    print_error "readConfig utility not found in PATH"
    exit 1
fi

print_info "Reading database path from vectorTools.ini..."

# Get database path from config
DATABASE_PATH=$(readConfig vectorTools vectorTools.databaseFilePath 2>/dev/null | tail -1)

if [ -z "$DATABASE_PATH" ]; then
    print_error "Failed to get database path from vectorTools.ini"
    exit 1
fi

print_info "Database path: $DATABASE_PATH"

# Check if database file exists
if [ ! -f "$DATABASE_PATH" ]; then
    print_error "Database file does not exist: $DATABASE_PATH"
    exit 1
fi

# Parse path components
DATABASE_DIR=$(dirname "$DATABASE_PATH")
DATABASE_FILE=$(basename "$DATABASE_PATH")
DATABASE_NAME="${DATABASE_FILE%.*}"
DATABASE_EXT="${DATABASE_FILE##*.}"

# Create backup directory structure
BACKUP_ROOT="$DATABASE_DIR/zBACKUPS"
BACKUP_DIR="$BACKUP_ROOT/$DATABASE_NAME"

print_info "Creating backup directory: $BACKUP_DIR"
mkdir -p "$BACKUP_DIR"

# Generate timestamp
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")

# Create backup filename
BACKUP_FILE="${DATABASE_NAME}_${TIMESTAMP}.${DATABASE_EXT}"
BACKUP_PATH="$BACKUP_DIR/$BACKUP_FILE"

# Perform backup
print_info "Backing up database..."
print_info "Source: $DATABASE_PATH"
print_info "Destination: $BACKUP_PATH"

cp "$DATABASE_PATH" "$BACKUP_PATH"

if [ $? -eq 0 ]; then
    print_success "Backup created: $BACKUP_FILE"
else
    print_error "Failed to create backup"
    exit 1
fi

# Get file size for reporting
BACKUP_SIZE=$(ls -lh "$BACKUP_PATH" | awk '{print $5}')
print_info "Backup size: $BACKUP_SIZE"

# Prune old backups - keep only 10 most recent
print_info "Checking for old backups to prune..."

# Count existing backups
BACKUP_COUNT=$(ls -1 "$BACKUP_DIR"/${DATABASE_NAME}_*.${DATABASE_EXT} 2>/dev/null | wc -l)

if [ "$BACKUP_COUNT" -gt 10 ]; then
    # Calculate how many to delete
    DELETE_COUNT=$((BACKUP_COUNT - 10))
    print_info "Found $BACKUP_COUNT backups, removing $DELETE_COUNT oldest..."
    
    # Get list of files to delete (oldest first)
    FILES_TO_DELETE=$(ls -1t "$BACKUP_DIR"/${DATABASE_NAME}_*.${DATABASE_EXT} | tail -n $DELETE_COUNT)
    
    # Delete old backups
    for FILE in $FILES_TO_DELETE; do
        rm "$FILE"
        print_info "Removed old backup: $(basename "$FILE")"
    done
    
    print_success "Pruning complete. Kept 10 most recent backups."
else
    print_info "Current backup count: $BACKUP_COUNT (no pruning needed)"
fi

# Show current backups
print_info "Current backups in $BACKUP_DIR:"
ls -1t "$BACKUP_DIR"/${DATABASE_NAME}_*.${DATABASE_EXT} 2>/dev/null | head -10 | while read -r FILE; do
    SIZE=$(ls -lh "$FILE" | awk '{print $5}')
    echo "  - $(basename "$FILE") ($SIZE)"
done

print_success "Database backup complete!"